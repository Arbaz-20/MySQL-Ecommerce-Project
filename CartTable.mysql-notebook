    "content": "\\about\nuse ecommerce;\nCREATE TABLE carts (\n    id              CHAR(36)    NOT NULL DEFAULT (UUID()),\n    user_id         CHAR(36)    NOT NULL,\n    status          ENUM('active','converted','abandoned','merged') NOT NULL DEFAULT 'active',\n    currency        CHAR(3)     NOT NULL DEFAULT 'INR',\n    converted_order_id CHAR(36) DEFAULT NULL,        -- filled in at checkout\n\n    created_at      DATETIME    NOT NULL DEFAULT CURRENT_TIMESTAMP,\n    updated_at      DATETIME    NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,\n\n    -- only ONE active cart per user; NULLs (non-active) are exempt from the unique check\n    is_active_cart  TINYINT GENERATED ALWAYS AS\n                    (CASE WHEN status = 'active' THEN 1 ELSE NULL END) STORED,\n\n    PRIMARY KEY (id),\n    UNIQUE KEY uq_user_active_cart (user_id, is_active_cart),\n    KEY idx_carts_user (user_id),\n    KEY idx_carts_status (status),\n\n    CONSTRAINT fk_carts_user\n        FOREIGN KEY (user_id) REFERENCES users (id) ON DELETE CASCADE\n);\n\n\nCREATE TABLE cart_items (\n    id              CHAR(36)    NOT NULL DEFAULT (UUID()),\n    cart_id         CHAR(36)    NOT NULL,\n    product_id      CHAR(36)    NOT NULL,\n    quantity        INT UNSIGNED NOT NULL DEFAULT 1,\n    unit_price      DECIMAL(12,2) NOT NULL,           -- price snapshot when added\n    line_total      DECIMAL(12,2) GENERATED ALWAYS AS (unit_price * quantity) STORED,\n\n    created_at      DATETIME    NOT NULL DEFAULT CURRENT_TIMESTAMP,\n    updated_at      DATETIME    NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,\n\n    PRIMARY KEY (id),\n    -- same product in same cart = one row; re-adding bumps quantity instead of duplicating\n    UNIQUE KEY uq_cart_product (cart_id, product_id),\n    KEY idx_cart_items_product (product_id),\n\n    CONSTRAINT chk_qty CHECK (quantity > 0),\n    CONSTRAINT fk_items_cart\n        FOREIGN KEY (cart_id) REFERENCES carts (id) ON DELETE CASCADE,\n    CONSTRAINT fk_items_product\n        FOREIGN KEY (product_id) REFERENCES products (id) ON DELETE CASCADE\n);\nshow TABLES;\nSHOW TABLES;\nALTER TABLE carts\nADD CONSTRAINT fk_carts_order\n    FOREIGN KEY (converted_order_id) REFERENCES orders (id) ON DELETE SET NULL\nDESC orders;\nSELECT\n    kcu.TABLE_NAME,\n    kcu.COLUMN_NAME,\n    kcu.CONSTRAINT_NAME,\n    kcu.REFERENCED_TABLE_NAME,\n    kcu.REFERENCED_COLUMN_NAME,\n    rc.UPDATE_RULE,\n    rc.DELETE_RULE\nFROM information_schema.KEY_COLUMN_USAGE kcu\nJOIN information_schema.REFERENTIAL_CONSTRAINTS rc\n      ON  kcu.CONSTRAINT_NAME   = rc.CONSTRAINT_NAME\n      AND kcu.CONSTRAINT_SCHEMA = rc.CONSTRAINT_SCHEMA\nWHERE kcu.TABLE_SCHEMA = DATABASE()\n  AND kcu.REFERENCED_TABLE_NAME IS NOT NULL\nORDER BY kcu.TABLE_NAME, kcu.COLUMN_NAME;\n\n-- Seed data for `carts` and `cart_items`\n-- Uses real users (carts.user_id) and real products (cart_items.product_id).\n-- Generated columns is_active_cart / line_total are intentionally omitted.\n-- LOAD ORDER: users -> products -> carts -> cart_items.\n\nSTART TRANSACTION;\n\n-- ===== CARTS =====\nINSERT INTO carts (id, user_id, status, currency, converted_order_id) VALUES\n('0233197f-33dc-4b62-be30-a22438e554e0','814e3f2e-b60c-4a47-8281-1ca0ec1e3409','abandoned','USD',NULL),\n('8bedd673-844f-4352-95a6-42cb8418d32c','814e3f2e-b60c-4a47-8281-1ca0ec1e3409','active','USD',NULL),\n('3e79fbf5-db4e-424e-bd33-74ac3036cf89','8dd2d953-bc22-4542-a357-a488f6d53f03','merged','USD',NULL),\n('9a12011a-5471-497c-8373-f54b0bfdf91d','8dd2d953-bc22-4542-a357-a488f6d53f03','abandoned','USD',NULL),\n('eb3735c2-0cae-49b2-b42f-5f37ab321f00','8dd2d953-bc22-4542-a357-a488f6d53f03','active','USD',NULL),\n('09852462-6ce9-4727-8894-15844cf26248','8dd2d953-bc22-4542-a357-a488f6d53f03','merged','USD',NULL),\n('cff0aaa5-bd76-4730-a07c-10429e0f76e3','ca27bdda-0aa1-4a42-98be-f72275193470','active','USD',NULL),\n('980af40d-fe8e-45e7-8084-68c71c6178da','ca27bdda-0aa1-4a42-98be-f72275193470','abandoned','USD',NULL)